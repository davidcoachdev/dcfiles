# ~/.gitconfig — dcfiles-managed
#
# This file is managed by dcfiles. Local overrides go in ~/.gitconfig.local.

[user]
    name = Your Name
    email = you@example.com

[color]
    ui = auto

[core]
    editor = nano
    pager = less

[push]
    default = simple

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --all -20
